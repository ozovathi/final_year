<html>
<body><form method="post" action="O_Register.jsp" enctype="multipart/form-data">
              <table width="780" border="1" cellspacing="3" cellpadding="1">
                <tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>User Name (required)</strong></span></td>
                  <td><Input type="text" name="userid" placeholder="User Name" /></td>
                </tr>
                <tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Password (required)</strong></span></td>
                  <td><Input type="password" name="pass" placeholder="Password" /></td>
                </tr>
				<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Email Address (required)</strong></span></td>
                  <td><Input type="text" name="email" placeholder="test@gmail.com" /></td>
                </tr>
				<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Mobile Number (required)</strong></span></td>
                  <td><Input type="text" name="mobile" placeholder="Mobile Number" /></td>
                </tr>
					<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Your Address</strong></span></td>
                  <td ><input name="address" type="text" value="" placeholder="Address"></td>
                </tr>
				<tr>
				<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Date of Birth (required)</strong></span></td>
                  <td><Input type="text" name="dob" placeholder="DD/MM/YYYY" /></td>
                </tr>
				<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Select Gender (required)</strong></span></td>
                  
                  <td> <select id="s1" name="gender" class="text">
                  <option>--Select--</option>
                  <option>MALE</option>
                  <option>FEMALE</option>
                </select></td>
                </tr>
					<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Enter Pincode (required)</strong></span></td>
                  <td><Input type="text" name="pincode" placeholder="Enter PIN" /></td>
                </tr>
					<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Enter Location (required)</strong></span></td>
                  <td><Input type="text" name="location" placeholder="Location" /></td>
                </tr>
				<tr>
                  <td bgcolor="#FF0000"><span style="color:#FFFFFF" ><strong>Select Profile Picture (required)</strong></span></td>
                  <td><Input type="file" name="pic" placeholder="Browse Profile Picture" /></td>
                </tr>
			
                  <td>&nbsp;</td>
                  <td>&nbsp;</td>
                </tr>
                <tr>
                <td>
                  <td><input type="submit" value="Register"/></td>
                </tr>
  </table>
</form>
			  
</body>
			</html>  
	
          
             